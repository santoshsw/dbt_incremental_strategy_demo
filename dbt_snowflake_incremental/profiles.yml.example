shopflow_analytics:
  target: dev
  outputs:
    dev:
      type: databricks
      host: "dbc-21212121-afa2.cloud.databricks.com"
      http_path: "/sql/1.0/warehouses/YOUR_WAREHOUSE_ID"
      schema: silver
      catalog: workspace
      token: "dapi..."
      threads: 4
      connect_timeout: 60
      connect_retries: 3

    prod:
      type: databricks
      host: "{{ env_var('DATABRICKS_HOST', 'dbc-21212121-afa2.cloud.databricks.com') }}"
      http_path: "{{ env_var('DATABRICKS_HTTP_PATH') }}"
      schema: "{{ env_var('DBT_SCHEMA', 'silver') }}"
      catalog: "{{ env_var('DATABRICKS_CATALOG', 'workspace') }}"
      token: "{{ env_var('DATABRICKS_TOKEN') }}"
      threads: 8
      connect_timeout: 60
      connect_retries: 3
